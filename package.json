{
  "name": "@dymoo/fusion",
  "version": "0.1.0",
  "description": "Local fusion model provider: serves OpenAI- and Anthropic-compatible endpoints and routes to a single upstream model or a panel of models aggregated by a judge",
  "type": "module",
  "license": "MIT",
  "author": "dymoo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dymoo/fusion.git"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "claude-code",
    "opencode",
    "codex",
    "proxy",
    "router",
    "fusion",
    "agents"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "fusion": "dist/cli.js"
  },
  "files": [
    "dist",
    "config.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "check-all": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "test": "node --test dist/tests/*.test.js",
    "pretest": "tsc",
    "prepublishOnly": "pnpm run check-all && pnpm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "undici": "^7.0.0"
  }
}
